# LiveKit Cloud (or self-hosted) credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# AI provider API keys
DEEPGRAM_API_KEY=your-deepgram-key
GROQ_API_KEY=your-groq-key

# TTS (Text-to-Speech) - Primary provider
CARTESIA_API_KEY=your-cartesia-key
# Optional: Get available voice IDs by running: python cartesia_diagnostics.py
# Then set: CARTESIA_VOICE_ID=your-voice-id
# Default: 95856005-0332-474b-929b-33e888e1e037 (Zara voice)

# TTS Fallback - Used if Cartesia fails (highly recommended for stability)
OPENAI_API_KEY=your-openai-api-key
